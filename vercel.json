{
  "rewrites": [
    {
      "source": "/api/prayer-times",
      "destination": "/api/prayer-times.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate"
        }
      ]
    }
  ]
}